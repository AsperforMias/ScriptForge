# Copy this file to `.env.local` before running ScriptForge with a real LLM provider.
# The example values below target DeepSeek's OpenAI-compatible chat completions API.

APP_ENV=development
HTTP_ADDR=:8080
SQLITE_PATH=./tmp/scriptforge.db
ARTIFACT_DIR=./tmp/artifacts
JOB_MAX_CONCURRENCY=2
GENERATION_MODE_DEFAULT=llm

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=replace-with-your-real-provider-key
LLM_REQUEST_TIMEOUT=180s
